# ── JWT (required) ────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ── Credentials ───────────────────────────────────────────────────────────────
AUTH_USER=admin
AUTH_PASS=admin

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
SCANS_DIR=/scans
